# ====== Neon Postgres (WAJIB — jangan pakai DATABASE_URL="" kosong) ======
# Salin "Pooled connection" dari https://console.neon.tech (host berakhiran -pooler.)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# ====== Auth.js (NextAuth) ======
# Generate: openssl rand -base64 32
AUTH_SECRET="ganti-dengan-string-acak-32-byte"
AUTH_URL="http://localhost:3000"

# ====== Enkripsi nomor WA (AES-256-GCM) ======
# 32 bytes base64. Generate: openssl rand -base64 32
ENCRYPTION_KEY="ganti-dengan-key-32-byte-base64"

# ====== Starsender (WA Gateway) ======
# Dokumentasi: https://starsender.online — API key dari dashboard Starsender.
# STARSENDER_DEVICE_ID: isi jika akun multi-device (nomor device di panel, contoh "50").
STARSENDER_API_KEY="masukkan-api-key-starsender"
STARSENDER_DEVICE_ID=""
STARSENDER_BASE_URL="https://api.starsender.online/api"
# URL publik aplikasi untuk webhook callback
APP_URL="http://localhost:3000"

# ====== Cloudflare R2 (Storage Foto) ======
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="pupr-cimahi-photos"
# Public URL bucket (custom domain atau r2.dev URL)
R2_PUBLIC_URL="https://photos.pupr.cimahikota.go.id"

# ====== Cloudflare Turnstile (Captcha) ======
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# ====== Konfigurasi geofencing & duplikat ======
# Default boleh dikosongkan
DUPLICATE_RADIUS_METERS="75"
DAILY_REPORT_LIMIT_PER_WA="3"
